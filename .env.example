# MCP runtime
MCP_SERVER_NAME=media-stack-mcp
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_TOKEN=change_this_to_a_long_random_token
MCP_PUBLIC_URL=https://mcp.yourdomain.com/mcp
# Optional comma-separated hostnames/IPs accepted in Host headers, for example:
MCP_ALLOWED_HOSTS=mcp.yourdomain.com
LOG_LEVEL=info

# Cloudflare Tunnel sidecar. Create this token in the Cloudflare Zero Trust dashboard.
CLOUDFLARED_TOKEN=change_this_to_your_cloudflare_tunnel_token

# Your QNAP/media stack base URLs. Use container names if running in same Docker network.
RADARR_URL=http://radarr:7878
RADARR_API_KEY=change_me

SONARR_URL=http://sonarr:8989
SONARR_API_KEY=change_me

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=change_me

SABNZBD_URL=http://sabnzbd:8080
SABNZBD_API_KEY=change_me

QBITTORRENT_URL=http://vpn:5080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=change_me
